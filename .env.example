VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_SITE_URL=http://localhost:5173

# PDF generation configuration
# Options: 'browser' (default html2canvas/jsPDF) or 'puppeteer'
VITE_PDF_ENGINE=browser
# When using the Puppeteer engine, this endpoint will be invoked (defaults to /api/render-pdf)
# VITE_PDF_SERVICE_URL=http://localhost:3000/api/render-pdf
# Optional timeout (ms) for the Puppeteer fetch before falling back to browser rendering
VITE_PDF_SERVICE_TIMEOUT_MS=25000