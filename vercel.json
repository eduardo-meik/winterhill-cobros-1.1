{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Clear-Site-Data",
          "value": "\"cache\""
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
